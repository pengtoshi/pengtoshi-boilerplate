# GraphQL server base URL (without /graphql)
EXPO_PUBLIC_SERVER_URL=http://localhost:3000

# Kakao OAuth2
EXPO_PUBLIC_KAKAO_REST_API_KEY=your_kakao_rest_api_key
# Register this HTTPS callback URI in Kakao console.
EXPO_PUBLIC_KAKAO_REDIRECT_URI=https://your-server-domain.com/api/auth/kakao/callback
# App deep link URI used by server callback.
EXPO_PUBLIC_KAKAO_APP_REDIRECT_URI=client-expo://oauth/kakao
