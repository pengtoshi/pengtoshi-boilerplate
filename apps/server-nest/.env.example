# Example .env file for server-nest

# Nest
PORT=3000
NEST_ENVIRONMENT=local

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=localdb
DATABASE_USERNAME=localusername
DATABASE_PASSWORD=localpass

POSTGRES_PASSWORD=localpass
POSTGRES_USER=localusername
POSTGRES_DB=localdb

# Services
CLIENT_APP_URL=http://localhost:4200

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=localpass

# JWT
JWT_SECRET=secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=refresh
JWT_REFRESH_EXPIRES_IN=30d

# OAuth2
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_TOKEN_URL=https://kauth.kakao.com/oauth/token
KAKAO_USER_INFO_URL=https://kapi.kakao.com/v2/user/me
# Mobile OAuth callback (register this URL in Kakao console)
KAKAO_MOBILE_CALLBACK_URL=https://your-server-domain.com/api/auth/kakao/callback
# Deep link to return from server callback to Expo app
KAKAO_MOBILE_APP_REDIRECT_URI=client-expo://oauth/kakao

# Prisma database connection
PRISMA_DATABASE_URL=postgresql://localusername:localpass@localhost:5432/localdb?schema=public
READ_ONLY_PRISMA_DATABASE_URL=postgresql://localusername:localpass@localhost:5432/localdb?schema=public

# GraphQL
PLAYGROUND_ENABLED=true
SCHEMA_DESTINATION='./libs/graphql/schema.graphql'
SORT_SCHEMA=true
