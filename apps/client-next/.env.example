## Required
# GraphQL server base URL
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Kakao REST API key
NEXT_PUBLIC_KAKAO_REST_API_KEY=your_kakao_rest_api_key

# Kakao OAuth callback URL (registered in Kakao Developers)
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:4200/api/auth/callback/kakao

# Required for Next API route (/api/auth/callback/kakao)
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:4200/api/auth/callback/kakao
