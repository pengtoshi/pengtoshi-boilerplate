{
  "extends": ["plugin:@nx/react", "../../../.eslintrc.json"],
  "ignorePatterns": ["!**/*", "dist"],
  "overrides": [
    {
      "files": ["babel.config.js", "tailwind.config.js"],
      "extends": ["plugin:@typescript-eslint/disable-type-checked"]
    },
    {
      "files": ["*.ts", "*.tsx"],
      "parserOptions": {
        "project": ["libs/ui/mobile/tsconfig.*?.json"]
      },
      "rules": {}
    },
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {}
    },
    {
      "files": ["*.js", "*.jsx"],
      "extends": ["plugin:@typescript-eslint/disable-type-checked"],
      "rules": {}
    },
    {
      "files": ["**/*.stories.ts", "**/*.stories.tsx"],
      "extends": ["plugin:@typescript-eslint/disable-type-checked"],
      "parserOptions": {
        "project": null
      },
      "rules": {}
    }
  ]
}
