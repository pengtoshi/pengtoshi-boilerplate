{
  "name": "@pengtoshi-boilerplate/source",
  "version": "0.1.0",
  "license": "MIT",
  "scripts": {
    "build": "nx build",
    "build:all": "nx run-many --target=build --all --parallel=3",
    "check-branch-name": "chmod 755 tools/scripts/check_branch_naming.sh && sh tools/scripts/check_branch_naming.sh",
    "codegen:graphql": "graphql-codegen --config ./tools/graphql/graphql-codegen.ts",
    "codegen:sitemap-client-next": "ts-node tools/generators/sitemap.ts client-next",
    "docker:up": "docker-compose up -d",
    "docker:build": "ts-node --project ./deploy/tsconfig.json ./deploy/image-build.ts",
    "docker:deploy": "ts-node --project ./deploy/tsconfig.json ./deploy/image-deploy.ts",
    "deploy": "ts-node --project ./deploy/tsconfig.json ./deploy/service-deploy.ts",
    "db-migrate:dev": "dotenv -e ./apps/server-nest/.env.development -- prisma migrate dev --schema libs/prisma/schema.prisma",
    "db-migrate:dev:create-only": "dotenv -e ./apps/server-nest/.env.development -- prisma migrate dev --schema libs/prisma/schema.prisma --create-only",
    "db-migrate:dev:status": "dotenv -e ./apps/server-nest/.env.development -- prisma migrate status --schema libs/prisma/schema.prisma",
    "db-migrate:test": "dotenv -e ./apps/server-nest-e2e/.env.testing -- prisma migrate deploy --schema libs/prisma/schema.prisma",
    "db-migrate:deploy:local": "dotenv -e ./apps/server-nest/.env.development prisma migrate deploy --schema libs/prisma/schema.prisma",
    "db-migrate:deploy:qa": "dotenv -e ./apps/server-nest/.env.qa prisma migrate deploy --schema libs/prisma/schema.prisma",
    "db-migrate:deploy": "prisma migrate deploy --schema libs/prisma/schema.prisma",
    "db-sync": "ts-node --project ./tools/tsconfig.json ./tools/database/db-sync.ts postgres-db",
    "kill:all": "chmod 755 tools/scripts/kill_local_apps.sh && sh tools/scripts/kill_local_apps.sh",
    "lint:all": "nx run-many --target=lint --all --parallel=3",
    "lint-staged": "lint-staged --relative",
    "storybook": "nx storybook ui-web",
    "storybook:mobile": "nx run client-expo:storybook",
    "build-storybook": "nx build-storybook ui-web",
    "prepare": "npm-run-all prepare:*",
    "prepare:husky": "husky install",
    "prepare:commit-template": "git config commit.template .gitmessage.txt",
    "prepare:prisma": "prisma generate --schema libs/prisma/schema.prisma",
    "shadcn:add": "npx shadcn-ui add --cwd libs/ui-web",
    "start": "nx serve",
    "start:all": "docker-compose up -d && yarn kill:all && nx run-many --target=serve --all --parallel=5",
    "test": "nx test",
    "test:e2e-prepare": "yarn docker:up && dotenv -e ./apps/server-nest-e2e/.env.testing -- prisma migrate deploy --schema libs/prisma/schema.prisma",
    "test:all:without-prepare": "nx run-many --target=test --all",
    "test:all": "yarn test:e2e-prepare && yarn test:all:without-prepare"
  },
  "private": true,
