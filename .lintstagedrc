{
  "*.ts?(x)": ["prettier --write", "eslint --fix"],
  "libs/graphql/client/src/core/requests/!(__generated__)/**/*.ts?(x)": [
    "yarn codegen:graphql",
    "git add libs/graphql/client/src/core/requests/__generated__"
  ],
  "libs/model/src/lib/**/*.ts?(x)": [
    "yarn codegen:graphql",
    "git add libs/graphql/client/src/core/requests/__generated__"
  ]
}
