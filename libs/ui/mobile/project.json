{
  "name": "ui-mobile",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ui/mobile/src",
  "projectType": "library",
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/ui/mobile"],
      "options": {
        "jestConfig": "libs/ui/mobile/jest.config.js",
        "passWithNoTests": true
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/ui/mobile",
        "main": "libs/ui/mobile/src/index.ts",
        "tsConfig": "libs/ui/mobile/tsconfig.lib.json",
        "assets": ["libs/ui/mobile/*.md"]
      }
    }
  },
  "tags": ["scope:client"]
}
